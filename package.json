{
  "name": "spreadsheet-tax",
  "version": "1.20.0",
  "description": "HMRC MTD ITSA bridging-only app — local spreadsheet file to quarterly updates for self-employment and property landlords",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "worker": "node src/workers/job-runner.js",
    "test": "node --test tests/**/*.test.js",
    "test:unit": "node --test tests/**/*.test.js",
    "test:e2e": "playwright test",
    "generate:test-spreadsheets": "node scripts/generate-test-spreadsheets.js",
    "seed:capacity": "node scripts/seed-capacity.js",
    "seed:capacity:full": "CAPACITY_SEED_FULL=1 node scripts/seed-capacity.js",
    "load:capacity": "node scripts/load-test-capacity.js"
  },
  "author": "Lee Hine",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "hmrc",
    "mtd",
    "itsa",
    "bridging",
    "self-employment",
    "property",
    "uk-tax"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "express": "^4.21.2",
    "file-type": "^16.5.4",
    "ioredis": "^5.11.1",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0"
  }
}
