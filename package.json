{
  "name": "spreadsheet-tax",
  "version": "1.31.1",
  "description": "HMRC MTD ITSA bridging-only app — local spreadsheet file to quarterly updates for self-employment and property landlords",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "worker": "node src/workers/job-runner.js",
    "test": "CSRF_ENFORCE=0 node --test tests/**/*.test.js",
    "test:unit": "CSRF_ENFORCE=0 node --test tests/**/*.test.js",
    "test:security": "CSRF_ENFORCE=1 node --test tests/security-freeze.test.js",
    "test:e2e": "playwright test",
    "generate:test-spreadsheets": "node scripts/generate-test-spreadsheets.js",
    "seed:capacity": "node scripts/seed-capacity.js",
    "seed:capacity:full": "CAPACITY_SEED_FULL=1 node scripts/seed-capacity.js",
    "load:capacity": "node scripts/load-test-capacity.js",
    "migrate:sqlite-to-pg": "node scripts/migrate-sqlite-to-postgres.js",
    "capture:sales": "node scripts/capture-sales-site.mjs",
    "capacity:evidence": "bash scripts/capacity-evidence-run.sh",
    "capacity:migrate": "node -e \"import('./src/lib/pg-pool.js').then(m=>m.migratePostgres().then(()=>{console.log('ok');process.exit(0)}))\"",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major"
  },
  "author": "Lee Hine",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "hmrc",
    "mtd",
    "itsa",
    "bridging",
    "self-employment",
    "property",
    "uk-tax"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "express": "^4.21.2",
    "file-type": "^16.5.4",
    "ioredis": "^5.11.1",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0"
  }
}
